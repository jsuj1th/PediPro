{
  "name": "@pediform/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && rm -rf dist/seeds && cp -r src/seeds dist/seeds",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:tool": "tsx src/scripts/dbTools.ts",
    "db:status": "tsx src/scripts/dbTools.ts status",
    "db:tables": "tsx src/scripts/dbTools.ts tables",
    "db:counts": "tsx src/scripts/dbTools.ts counts",
    "db:schema": "tsx src/scripts/dbTools.ts schema",
    "db:view": "tsx src/scripts/dbTools.ts view",
    "db:query": "tsx src/scripts/dbTools.ts query",
    "db:migrate": "tsx src/scripts/dbTools.ts migrate",
    "db:seed": "tsx src/scripts/dbTools.ts seed",
    "db:reset": "tsx src/scripts/dbTools.ts reset",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.5"
  }
}
